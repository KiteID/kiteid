{
  "extends": "@kiteid/config-typescript/react",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", ".next"]
}
