{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "extends": ["./packages/config-biome/base.json"],
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/.turbo",
      "!**/packages/contracts/out",
      "!**/packages/contracts/cache",
      "!**/packages/contracts/broadcast",
      "!**/packages/contracts/lib",
      "!**/pnpm-lock.yaml",
      "!**/.changeset",
      "!**/coverage",
      "!**/next-env.d.ts",
      "!**/apps/docs/.source",
      "!**/ponder-env.d.ts",
      "!**/playwright-report",
      "!**/test-results",
      "!**/blob-report"
    ]
  }
}
