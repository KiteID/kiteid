{
  "name": "kiteid",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:contracts": "turbo run test:contracts",
    "db:generate": "turbo run db:generate --filter=@kiteid/db",
    "db:migrate": "turbo run db:migrate --filter=@kiteid/db",
    "clean": "turbo run clean",
    "prepare": "lefthook install"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook",
      "sharp"
    ],
    "overrides": {
      "axios": ">=1.15.2",
      "follow-redirects": ">=1.16.0",
      "happy-dom": ">=20.8.9",
      "kysely": "0.28.17",
      "esbuild": ">=0.25.0",
      "hono": ">=4.12.18",
      "@hono/node-server": ">=1.19.13",
      "uuid": ">=14.0.0",
      "zod": "4.3.6",
      "viem": "2.47.12",
      "wagmi": "2.19.5",
      "fast-uri": ">=3.1.2",
      "postcss": ">=8.5.14"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-39356"
      ],
      "ignoreGhsas": [
        "GHSA-4w7w-66w2-5vf9",
        "GHSA-qx2v-qp2m-jg93"
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "lefthook": "^2.1.6",
    "rimraf": "^6.0.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
