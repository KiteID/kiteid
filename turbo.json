{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:contracts": {
      "cache": false
    },
    "test:contracts:fuzz": {
      "cache": false
    },
    "test:contracts:invariant": {
      "cache": false
    },
    "wagmi:generate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
