{
  "name": "@kiteid/contracts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:contracts": "forge test -vvv",
    "test:contracts:fuzz": "forge test --match-test testFuzz -vvv",
    "test:contracts:invariant": "forge test --match-test invariant -vvv",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "snapshot": "forge snapshot",
    "abi:export": "forge build && node scripts/export-abis.mjs && pnpm exec biome check --write ../contracts-abi/src/abis ../contracts-abi/src/index.ts",
    "clean": "forge clean"
  }
}
